# Copy this file to .env.local and fill in your real project values.
# Never commit .env.local.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Terrifying Towering global multiplayer.
# In production on Vercel, this must point to the always-on Socket.IO server.
VITE_SOCKET_URL=https://your-tower-socket-host.example

# Optional: set to true in local dev when you want Vite to use VITE_SOCKET_URL
# instead of the local Socket.IO server at http://localhost:3001.
VITE_USE_REMOTE_SOCKET=false

# Socket server host variables, set on Render/Railway/Fly/VPS rather than Vercel.
# PORT=3001
# CLIENT_ORIGIN=https://your-vercel-app.vercel.app
